      "ai": {
        "title": "AI",
        "intro": "Your data on AT Protocol is public — these settings tell AI services how they may use it. Akari respects your choices and shares them with other services, who can choose to respect them. Bad actors may ignore these signals; that's outside our control. The preferences apply across your entire account. Safety tools like spam and bot detection aren't affected.",
        "section": "How AI may use your data",
        "training": {
          "label": "Allow training",
          "hint": "Use your posts to build or train AI models. Once your data is part of a model, it stays there even if you later delete your account."
        },
        "inference": {
          "label": "Allow inference",
          "hint": "Let AI look up your posts when answering someone's question. The AI doesn't keep your data, but may quote or reference it in real time."
        },
        "embedding": {
          "label": "Allow embedding",
          "hint": "Let AI search and recommendation systems use your posts — finding similar accounts, grouping users by interests, deciding what to surface in feeds like Discover or For You."
        },
        "syntheticContent": {
          "label": "Allow synthetic content",
          "hint": "Let AI generate new content modeled on your data — imitations of your writing, AI versions of your photos or audio, or bots designed to sound like you."
