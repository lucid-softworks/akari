{
  "name": "akari",
  "main": "expo-router/entry",
  "version": "1.12.0",
  "scripts": {
    "postinstall": "cd ../.. && npm run build",
    "eas-build-pre-install": "node ./scripts/write-build-env.js",
    "start": "expo start",
    "start:development": "APP_VARIANT=development expo start",
    "start:preview": "APP_VARIANT=preview expo start",
    "start:production": "APP_VARIANT=production expo start",
    "android": "expo run:android",
    "android:development": "APP_VARIANT=development expo run:android",
    "android:preview": "APP_VARIANT=preview expo run:android",
    "android:production": "APP_VARIANT=production expo run:android",
    "ios": "expo run:ios",
    "ios:development": "APP_VARIANT=development expo run:ios",
    "ios:preview": "APP_VARIANT=preview expo run:ios",
    "ios:production": "APP_VARIANT=production expo run:ios",
    "web": "expo start --web",
    "web:development": "APP_VARIANT=development expo start --web",
    "web:preview": "APP_VARIANT=preview expo start --web",
    "web:production": "APP_VARIANT=production expo start --web",
    "preview-web": "npx expo export -p web && npx serve dist -l 8088 --single",
    "build": "APP_VARIANT=${APP_VARIANT:-development} expo export",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:preview": "APP_VARIANT=preview expo export",
    "build:production": "APP_VARIANT=production expo export",
    "sync-oauth-meta": "node ./scripts/sync-oauth-meta.js",
    "lint": "oxlint",
    "test": "jest",
    "test:run": "jest --coverage=false",
    "test:coverage": "jest --coverage && cp ../../coverage-styles/*.css coverage/",
    "deploy": "node ./scripts/sync-oauth-meta.js && APP_VARIANT=${APP_VARIANT:-production} npx expo export -p web && eas deploy",
    "deploy:preview": "APP_VARIANT=preview npm run deploy",
    "deploy:prod": "APP_VARIANT=production npm run deploy -- --prod",
    "testflight": "APP_VARIANT=production eas build --platform ios --profile production --auto-submit",
    "testflight:submit": "APP_VARIANT=production eas submit --platform ios --profile production --latest",
    "playstore": "APP_VARIANT=production eas build --platform android --profile production --auto-submit",
    "playstore:submit": "APP_VARIANT=production eas submit --platform android --profile production --latest",
    "release": "APP_VARIANT=production eas build --platform all --profile production --auto-submit",
    "reset-project": "node ./scripts/reset-project.js",
    "update-translations": "node ./scripts/update-translations.js",
    "find-unused-translations": "node ./scripts/find-unused-translations.js"
  },
  "dependencies": {
    "@akari/axiom-crash-reporter": "*",
    "@atcute/bluesky-richtext-parser": "^1.0.7",
    "@expo/vector-icons": "^15.0.2",
    "@formatjs/intl-displaynames": "^6.8.11",
    "@formatjs/intl-getcanonicallocales": "^2.5.5",
    "@formatjs/intl-locale": "^4.2.11",
    "@formatjs/intl-numberformat": "^8.15.4",
    "@formatjs/intl-pluralrules": "^5.4.4",
    "@formatjs/intl-relativetimeformat": "^11.4.11",
    "@keytrace/claims": "^1.4.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native/assets-registry": "0.81.5",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/query-async-storage-persister": "^5.83.0",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-query-devtools": "^5.83.0",
    "@tanstack/react-query-persist-client": "^5.83.0",
    "@tanstack/react-virtual": "^3.13.24",
    "bluesky-api": "*",
    "bluesky-ozone": "*",
    "clearsky-api": "*",
    "constellation-api": "*",
    "expo": "~56.0.8",
    "expo-application": "~56.0.3",
    "expo-background-task": "~56.0.16",
    "expo-blur": "~56.0.3",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-image-picker": "~56.0.15",
    "expo-insights": "~56.0.15",
    "expo-linking": "~56.0.13",
    "expo-localization": "~56.0.6",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.8",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.17",
    "expo-video": "~56.1.2",
    "expo-watermark": "^0.2.0",
    "expo-web-browser": "~56.0.5",
    "hls.js": "^1.6.7",
    "i18n-js": "^4.5.1",
    "libretranslate-api": "*",
    "lucide-react-native": "^1.14.0",
    "pseudo-localization": "^3.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-intl": "^7.1.11",
    "react-native": "0.85.3",
    "react-native-exception-handler": "^2.10.10",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "^3.3.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-video": "^6.16.1",
    "react-native-web": "^0.21.0",
    "react-native-webrtc": "^124.0.5",
    "react-native-webview": "13.16.1",
    "react-simple-pull-to-refresh": "^1.3.4",
    "rn-emoji-keyboard": "^1.7.0",
    "slingshot-api": "*",
    "tenor-api": "*",
    "tmdb-api": "*"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@config-plugins/react-native-webrtc": "^13.0.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "^19.0.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint-plugin-i18next": "^6.1.3",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.4",
    "jsdom": "^27.0.0",
    "oxlint-plugin-react-doctor": "^0.2.0-beta.6",
    "patch-package": "^8.0.1",
    "react-test-renderer": "19.2.3",
    "ts-jest": "^29.4.1",
    "typescript": "~6.0.3"
  },
  "private": true
}
