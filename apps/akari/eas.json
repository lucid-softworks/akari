{
  "cli": {
    "version": ">= 16.17.3",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_VARIANT": "development",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "ci": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_VARIANT": "development",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_VARIANT": "preview",
        "SENTRY_DISABLE_AUTO_UPLOAD": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "APP_VARIANT": "production",
        "SENTRY_DISABLE_AUTO_UPLOAD": "false"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "companyName": "Lucid Softworks",
        "ascAppId": "6754194000",
        "bundleIdentifier": "works.lucidsoft.akari"
      }
    },
    "preview": {
      "ios": {
        "companyName": "Lucid Softworks",
        "ascAppId": "6766172137",
        "bundleIdentifier": "works.lucidsoft.akari.dev"
      }
    }
  }
}
