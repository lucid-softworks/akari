{
  "name": "akari-monorepo",
  "private": true,
  "version": "1.12.0",
  "packageManager": "npm@11.6.0",
  "engines": {
    "node": "24.9.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npx patch-package --patch-dir patches",
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "build": "APP_VARIANT=${APP_VARIANT:-development} turbo run build",
    "build:preview": "APP_VARIANT=preview turbo run build",
    "build:production": "APP_VARIANT=production turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --filter=akari",
    "test:coverage": "turbo run test:coverage --filter=akari && npm run merge-coverage",
    "merge-coverage": "node scripts/merge-coverage.cjs",
    "clean": "turbo run clean",
    "start:development": "turbo run start:development --filter=akari",
    "start:preview": "turbo run start:preview --filter=akari",
    "start:production": "turbo run start:production --filter=akari",
    "ios": "turbo run ios --filter=akari",
    "ios:development": "turbo run ios:development --filter=akari",
    "ios:preview": "turbo run ios:preview --filter=akari",
    "ios:production": "turbo run ios:production --filter=akari",
    "android": "turbo run android --filter=akari",
    "android:development": "turbo run android:development --filter=akari",
    "android:preview": "turbo run android:preview --filter=akari",
    "android:production": "turbo run android:production --filter=akari",
    "web": "turbo run web --filter=akari",
    "web:development": "turbo run web:development --filter=akari",
    "web:preview": "turbo run web:preview --filter=akari",
    "web:production": "turbo run web:production --filter=akari",
    "web:test": "node ./scripts/start-expo-web.cjs",
    "reset-project": "node ./scripts/reset-project.js",
    "update-translations": "node ./scripts/update-translations.js",
    "find-unused-translations": "node ./scripts/find-unused-translations.js",
    "react-doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@atcute/bluesky-richtext-parser": "^1.0.7",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.2",
    "@formatjs/intl-displaynames": "^6.8.11",
    "@formatjs/intl-getcanonicallocales": "^2.5.5",
    "@formatjs/intl-locale": "^4.2.11",
    "@formatjs/intl-numberformat": "^8.15.4",
    "@formatjs/intl-pluralrules": "^5.4.4",
    "@formatjs/intl-relativetimeformat": "^11.4.11",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@tanstack/query-async-storage-persister": "^5.83.0",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-query-devtools": "^5.83.0",
    "@tanstack/react-query-persist-client": "^5.83.0",
    "expo": "~56.0.8",
    "expo-background-task": "~56.0.16",
    "expo-blur": "~56.0.3",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-dev-client": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-image-picker": "~56.0.15",
    "expo-linking": "~56.0.13",
    "expo-localization": "~56.0.6",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.8",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-video": "~56.1.2",
    "expo-web-browser": "~56.0.5",
    "hls.js": "^1.6.7",
    "i18n-js": "^4.5.1",
    "pseudo-localization": "^3.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-intl": "^7.1.11",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "^3.3.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-video": "^6.16.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "jest-junit": "17.0.0",
    "oxlint": "^1.65.0",
    "turbo": "^2.3.0",
    "vite": "^8.0.10"
  },
  "overrides": {
    "@hono/node-server": "1.19.14",
    "@tootallnate/once": "3.0.1",
    "@xmldom/xmldom": "0.8.13",
    "flatted": "3.4.2",
    "handlebars": "4.7.9",
    "hono": "4.12.21",
    "lodash": "4.18.1",
    "node-forge": "1.4.0",
    "postcss": "8.5.13",
    "react-test-renderer": "19.2.3",
    "rollup": "4.59.0",
    "serialize-javascript": "7.0.5",
    "tar": "7.5.13",
    "undici": "6.24.0",
    "uuid": "14.0.0",
    "vite": "^8.0.10",
    "webpack": "5.106.2"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.28.0",
    "@oxlint/binding-linux-x64-gnu": "1.66.0",
    "@rolldown/binding-linux-x64-gnu": "^1.0.1",
    "@sentry/cli-linux-x64": "3.4.1",
    "@swc/core-linux-x64-gnu": "1.15.33",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
