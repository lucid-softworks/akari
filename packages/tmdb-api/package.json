{
  "name": "tmdb-api",
  "version": "1.0.0",
  "type": "module",
  "description": "TMDB API client for movie and TV show search",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest --config ./jest.config.cjs",
    "test:run": "jest --config ./jest.config.cjs",
    "test:coverage": "jest --config ./jest.config.cjs --coverage",
    "lint": "oxlint src"
  },
  "keywords": [
    "tmdb",
    "api",
    "movies",
    "tv"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "~29.7.0",
    "msw": "^2.4.9",
    "ts-jest": "^29.4.1",
    "typescript": "~5.8.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0"
  }
}
